{
  "colors": {
    "sena-green": "#39a900",
    "sena-green-dark": "#2d8600",
    "sena-green-light": "#e8f5e0",
    "neutral": {
      "50": "#f7f8fa",
      "100": "#eef0f4",
      "200": "#e1e5ed",
      "300": "#c5cad6",
      "500": "#7c8399",
      "700": "#4a5064",
      "800": "#2d3142",
      "900": "#1a1d29"
    },
    "semantic": {
      "success": "#15803d",
      "warning": "#b45309",
      "error": "#b91c1c",
      "info": "#1d4ed8"
    },
    "roles": {
      "psicologia": "#166534",
      "enfermeria": "#6b21a8",
      "trabajo_social": "#c2410c",
      "coordinacion": "#1e40af",
      "aprendiz": "#15803d"
    }
  },
  "typography": {
    "font-family": "Inter, system-ui, -apple-system, sans-serif",
    "scale": {
      "display": { "size": "clamp(1.5rem, 3vw, 2.25rem)", "weight": 800 },
      "h1": { "size": "clamp(1.25rem, 2.5vw, 1.75rem)", "weight": 700 },
      "h2": { "size": "clamp(1.125rem, 2vw, 1.5rem)", "weight": 600 },
      "h3": { "size": "clamp(1rem, 1.5vw, 1.25rem)", "weight": 600 },
      "body": { "size": "clamp(0.875rem, 1.2vw, 1rem)", "weight": 400 },
      "small": { "size": "clamp(0.75rem, 1vw, 0.875rem)", "weight": 400 },
      "mono": { "size": "0.875rem", "weight": 500 }
    }
  },
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem",
    "2xl": "3rem",
    "3xl": "4rem"
  },
  "radius": {
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "xl": "20px",
    "2xl": "24px",
    "full": "9999px"
  },
  "shadows": {
    "card-sm": "0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04)",
    "card-md": "0 4px 12px rgba(0,0,0,0.08)",
    "card-lg": "0 8px 24px rgba(0,0,0,0.10)",
    "card-hover": "0 12px 36px rgba(0,0,0,0.14)",
    "modal": "0 20px 60px rgba(0,0,0,0.20)",
    "sidebar": "-4px 0 24px rgba(0,0,0,0.12)"
  },
  "transition": {
    "ease-out-quart": "cubic-bezier(0.25, 1, 0.5, 1)",
    "ease-spring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "durations": {
      "instant": "100ms",
      "fast": "200ms",
      "normal": "300ms",
      "slow": "500ms"
    }
  },
  "accessibility": {
    "contrast-ratio": "7:1 (WCAG AAA)",
    "focus-indicator": "2px solid var(--sena-green), offset 2px",
    "skip-link": true,
    "keyboard-nav": true,
    "aria-required": true
  }
}
